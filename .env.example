# Server
PORT=3000
NODE_ENV=development

# Database (MySQL / MariaDB)
# The app auto-creates the database and tables on first start.
# The DB user needs CREATE/ALTER/INDEX privileges (and CREATE DATABASE if DB_NAME
# does not already exist). Point these at your server's MySQL/MariaDB instance.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=stayback_routes
# Optional: connection pool size
DB_CONNECTION_LIMIT=10

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=12h

# SmartPing WhatsApp API (api-wa.co campaign API)
# Set WHATSAPP_ENABLED=true and SMARTPING_API_KEY to send for real.
# While disabled, messages are logged as "Sent" (simulation) so you can test the flow.
WHATSAPP_ENABLED=false
SMARTPING_API_KEY=
SMARTPING_API_URL=https://backend.api-wa.co/campaign/smartpingbsp/api/v2
SMARTPING_CAMPAIGN_NAME=staybacktransport
SMARTPING_USERNAME=Digital Caampus
SMARTPING_SOURCE=stay-back-route-management
# Optional: prefix this country code to bare 10-digit numbers (e.g. 91 for India)
SMARTPING_COUNTRY_CODE=91
